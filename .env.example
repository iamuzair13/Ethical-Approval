# NextAuth — use the same port as `npm run dev` (default in this project: 3001)
NEXTAUTH_URL=http://localhost:3001
# Generate e.g. `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Google OAuth (Google Cloud Console → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SAP OData Basic Auth (required for student verification)
SAP_BASIC_AUTH_USERNAME=
SAP_BASIC_AUTH_PASSWORD=

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.htklelgvnulanmxqhgpa.supabase.co:5432/postgres
# Optional alternative (avoids URL issues with special chars in password):
# DB_HOST=db.htklelgvnulanmxqhgpa.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
